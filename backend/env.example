# Copiar para .env e preencher (nunca commitar .env)

DATABASE_URL=sqlite:///./sync2meet.db
APP_ENV=development
APP_PUBLIC_URL=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
STORAGE_DIR=./storage
API_HOST=0.0.0.0
API_PORT=8000

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Transcrição: openai = rápido (~5-15 min/hora) | local = grátis mas lento em CPU | auto = OpenAI se houver chave
TRANSCRIBE_PROVIDER=openai
FASTER_WHISPER_MODEL=base
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_CPU_THREADS=0
FASTER_WHISPER_BEAM_SIZE=1

SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=#general

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Sync2meet <no-reply@sync2meet.app>
SMTP_USE_TLS=true

AUTH_ENABLED=true
AUTH_SECRET=gere-uma-string-aleatoria-longa
AUTH_TOKEN_HOURS=24
PASSWORD_RESET_HOURS=1
ALLOW_REGISTRATION=true
MAX_TEAM_USERS=0
MEETING_RETENTION_DAYS=15
# Vazio = qualquer email pode registar/entrar
ALLOWED_EMAIL_DOMAINS=
# Emails promovidos a admin no arranque (ex.: tu@empresa.pt,outro@empresa.pt)
ADMIN_EMAILS=
TRUSTED_PROXY=false
DEV_AUTH_BYPASS=false
JOB_PENDING_STALE_MINUTES=30
TEAM_USERS=
MAX_UPLOAD_BYTES=2147483648
FFMPEG_TIMEOUT_SECONDS=3600
JOB_STALE_MINUTES=360
