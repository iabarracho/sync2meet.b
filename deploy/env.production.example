# Copiar para /opt/sync2meet/.env no servidor (ajustar domínio e passwords)

APP_ENV=production
APP_PUBLIC_URL=https://sync2meet.teudominio.pt
CORS_ORIGINS=https://sync2meet.teudominio.pt

DATABASE_URL=sqlite:////var/lib/sync2meet/sync2meet.db
STORAGE_DIR=/var/lib/sync2meet/storage
API_HOST=0.0.0.0
API_PORT=8000

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

FASTER_WHISPER_MODEL=base
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8
FASTER_WHISPER_LANGUAGE=

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Sync2meet <email-verificado@brevo.com>
SMTP_USE_TLS=true

AUTH_ENABLED=true
AUTH_SECRET=gere-uma-string-aleatoria-longa-com-openssl-rand
AUTH_TOKEN_HOURS=24
ALLOW_REGISTRATION=true
MAX_TEAM_USERS=30
MEETING_RETENTION_DAYS=15
ALLOWED_EMAIL_DOMAINS=bocaboca.pt
